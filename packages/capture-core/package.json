{
  "name": "@insitue/capture-core",
  "version": "0.3.5",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "description": "The seam: pure, transport/agent/fs-free capture model shared by every InSitue vehicle.",
  "keywords": [
    "insitue",
    "capture",
    "schema",
    "shared-types",
    "react",
    "dom",
    "visual-feedback",
    "source-resolution"
  ],
  "license": "MIT",
  "homepage": "https://www.insitue.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/InSitue/insitue.git",
    "directory": "packages/capture-core"
  },
  "bugs": {
    "url": "https://github.com/InSitue/insitue/issues"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=24"
  }
}
