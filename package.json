{
  "name": "insitu",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "companion": "pnpm --filter @insitu/companion run start",
    "test": "turbo run build && pnpm --filter @insitu/companion run test",
    "license:check": "license-checker --production --onlyAllow 'MIT;MIT OR X11;ISC;Apache-2.0;BSD-2-Clause;BSD-3-Clause;0BSD;CC0-1.0;Unlicense'"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "license-checker": "^25.0.1",
    "tsup": "^8.3.5",
    "turbo": "^2.3.3",
    "typescript": "^5.6.3"
  }
}
