# Hoist the InSitue SWC plugin to the workspace's top-level
# node_modules. Next.js's SWC plugin loader resolves WASM plugins
# by walking up node_modules from its own install location; in
# pnpm's default isolated layout, the plugin lives in
# `node_modules/.pnpm/@insitue+swc-source-attr@x.y.z/` which is
# invisible to that walk. The Vercel build fails with:
#
#   Cannot find module '/vercel/path0/node_modules/.pnpm/
#     node_modules/@insitue/swc-source-attr/
#     insitue_swc_source_attr.wasm'
#
# Hoisting puts a copy / symlink at the workspace root's
# node_modules where Next can find it. Narrow pattern — only this
# one package is affected; the rest of the workspace stays
# isolated.
public-hoist-pattern[]=*swc-source-attr*

# Keep pnpm's strict peer-dependency behaviour everywhere else.
# (Explicit so contributors understand the setting is intentional
# and the hoist above is a targeted workaround, not a slippery
# slope.)
strict-peer-dependencies=false
